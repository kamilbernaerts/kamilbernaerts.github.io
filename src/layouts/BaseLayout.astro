---
interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description = "Political scientist studying polarisation, democracy, and democratic resilience.", lang = "en" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Dr. Kamil Bernaerts</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={`${title} — Dr. Kamil Bernaerts`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="canonical" href={`https://kamilbernaerts.com${currentPath}`} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a href="/" class="site-name">Dr. Kamil Bernaerts</a>
      <nav>
        <ul class="site-nav">
          <li><a href="/" class={currentPath === '/' ? 'active' : ''}>Home</a></li>
          <li><a href="/research/" class={currentPath.startsWith('/research') ? 'active' : ''}>Research</a></li>
          <li><a href="/phd/" class={currentPath.startsWith('/phd') ? 'active' : ''}>PhD</a></li>
          <li><a href="/teaching/" class={currentPath.startsWith('/teaching') ? 'active' : ''}>Teaching</a></li>
          <li><a href="/outreach/" class={currentPath.startsWith('/outreach') ? 'active' : ''}>Outreach</a></li>
          <li><a href="/cv/" class={currentPath.startsWith('/cv') ? 'active' : ''}>CV</a></li>
          <li><a href="/contact/" class={currentPath.startsWith('/contact') ? 'active' : ''}>Contact</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-links">
        <a href="https://scholar.google.com/citations?user=7Pmo70UAAAAJ&hl=en" target="_blank" rel="noopener">Google Scholar</a>
        <a href="https://researchportal.vub.be/en/persons/kamil-bernaerts" target="_blank" rel="noopener">VUB Research Portal</a>
        <a href="https://orcid.org/0000-0002-3380-6639" target="_blank" rel="noopener">ORCID</a>
        <a href="https://kamilbernaerts.bsky.social" target="_blank" rel="noopener">Bluesky</a>
        <a href="https://be.linkedin.com/in/kamil-bernaerts-431753201" target="_blank" rel="noopener">LinkedIn</a>
      </div>
      <p class="footer-copy">&copy; {new Date().getFullYear()} Kamil Bernaerts. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
