---
interface Props {
  title: string;
  description?: string;
  lang?: string;
}
const { title, description = "Political scientist studying polarisation, democracy, and democratic resilience.", lang = "en" } = Astro.props;
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang={lang}>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Dr. Kamil Bernaerts</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={`${title} — Kamil Bernaerts`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="canonical" href={`https://kamilbernaerts.com${currentPath}`} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script data-goatcounter="https://kamilbernaerts.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
<head>
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a href="/" class="site-name">Dr. Kamil Bernaerts</a>
      <nav class="desktop-nav">
        <ul class="site-nav">
          <li><a href="/" class={currentPath === '/' ? 'active' : ''}>Home</a></li>
          <li><a href="/research/" class={currentPath.startsWith('/research') ? 'active' : ''}>Research</a></li>
          <li><a href="/phd/" class={currentPath.startsWith('/phd') ? 'active' : ''}>PhD</a></li>
          <li><a href="/teaching/" class={currentPath.startsWith('/teaching') ? 'active' : ''}>Teaching</a></li>
          <li><a href="/outreach/" class={currentPath.startsWith('/outreach') ? 'active' : ''}>Outreach</a></li>
          <li><a href="/writing/" class={currentPath.startsWith('/writing') ? 'active' : ''}>Writing</a></li>
          <li><a href="/cv/" class={currentPath.startsWith('/cv') ? 'active' : ''}>CV</a></li>
          <li><a href="/contact/" class={currentPath.startsWith('/contact') ? 'active' : ''}>Contact</a></li>
        </ul>
      </nav>
      <button class="menu-toggle" aria-label="Toggle menu" id="menuToggle">
        <span class="menu-bar"></span>
        <span class="menu-bar"></span>
      </button>
    </div>
  </header>

  <!-- Mobile menu overlay -->
  <div class="mobile-menu" id="mobileMenu">
    <nav>
      <a href="/" class={currentPath === '/' ? 'active' : ''}>Home</a>
      <a href="/research/" class={currentPath.startsWith('/research') ? 'active' : ''}>Research</a>
      <a href="/phd/" class={currentPath.startsWith('/phd') ? 'active' : ''}>PhD</a>
      <a href="/teaching/" class={currentPath.startsWith('/teaching') ? 'active' : ''}>Teaching</a>
      <a href="/outreach/" class={currentPath.startsWith('/outreach') ? 'active' : ''}>Outreach</a>
      <a href="/writing/" class={currentPath.startsWith('/writing') ? 'active' : ''}>Writing</a>
      <a href="/cv/" class={currentPath.startsWith('/cv') ? 'active' : ''}>CV</a>
      <a href="/contact/" class={currentPath.startsWith('/contact') ? 'active' : ''}>Contact</a>
    </nav>
    <div class="mobile-menu__footer">
      <a href="mailto:kamil.bernaerts@vub.be">kamil.bernaerts@vub.be</a>
    </div>
  </div>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-links">
        <a href="https://scholar.google.com/citations?user=7Pmo70UAAAAJ&hl=en" target="_blank" rel="noopener">Google Scholar</a>
        <a href="https://researchportal.vub.be/en/persons/kamil-bernaerts" target="_blank" rel="noopener">VUB Research Portal</a>
        <a href="https://orcid.org/0000-0002-3380-6639" target="_blank" rel="noopener">ORCID</a>
        <a href="https://kamilbernaerts.bsky.social" target="_blank" rel="noopener">Bluesky</a>
        <a href="https://be.linkedin.com/in/kamil-bernaerts-431753201" target="_blank" rel="noopener">LinkedIn</a>
      </div>
      <p class="footer-copy">&copy; {new Date().getFullYear()} Kamil Bernaerts. All rights reserved.</p>
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('menuToggle');
    const menu = document.getElementById('mobileMenu');
    toggle?.addEventListener('click', () => {
      menu?.classList.toggle('open');
      toggle.classList.toggle('open');
    });

    let lastScroll = 0;
    const header = document.querySelector('.site-header');
    window.addEventListener('scroll', () => {
      const current = window.scrollY;
      if (current < lastScroll || current < 50) {
        header.classList.remove('header-hidden');
      } else {
        header.classList.add('header-hidden');
      }
      lastScroll = current;
    });
  </script>
</body>
</html>
<style is:global>
  @import '../styles/global.css';
</style>
