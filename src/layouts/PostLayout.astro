---
// src/layouts/PostLayout.astro
// Gedeelde lay-out voor alle blog posts.
// Gebruik dit via de 'layout' frontmatter in je .md bestanden.

export interface Props {
  title: string;
  description?: string;
  date: string;           // bv. "20 oktober 2022"
  lang?: string;          // "NL" of "EN" (optioneel)
  venue?: string;         // bv. "Stuk Rood Vlees" (optioneel — weglaten bij originele posts)
  venueUrl?: string;      // URL van de oorspronkelijke publicatie (optioneel)
  authors?: string;       // bv. "met Benjamin Blanckaert & Didier Caluwaerts" (optioneel)
  tags?: string[];        // bv. ["Polarisatie", "Democratie"] (optioneel)
}

const { title, description, date, lang, venue, venueUrl, authors, tags } = Astro.props;

import BaseLayout from './BaseLayout.astro';
---

<BaseLayout title={title} description={description}>

  <!-- PAGE HEADER -->
  <div class="page-header">
    <div class="container--narrow">
      <p style="font-size: 0.75rem; margin-bottom: 0.75rem;">
        <a href="/writing/" style="color: var(--color-text-muted);">← Writing</a>
      </p>

      <!-- Meta: datum + venue + taal -->
      <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; font-size: 0.75rem; color: var(--color-text-faint); margin-bottom: 1rem;">
        <span>{date}</span>
        {venue && venueUrl && (
          <>
            <span>·</span>
            <a href={venueUrl} target="_blank" rel="noopener" style="color: var(--color-accent); font-weight: 500;">{venue}</a>
          </>
        )}
        {venue && !venueUrl && (
          <>
            <span>·</span>
            <span style="color: var(--color-accent); font-weight: 500;">{venue}</span>
          </>
        )}
        {lang && (
          <>
            <span>·</span>
            <span style="padding: 0.125rem 0.5rem; border: 1px solid var(--color-border); border-radius: 10px; color: var(--color-text-muted);">{lang}</span>
          </>
        )}
      </div>

      <h1>{title}</h1>

      {authors && (
        <p style="font-size: 0.8125rem; color: var(--color-text-muted); margin-top: 0.5rem; margin-bottom: 0;">{authors}</p>
      )}
    </div>
  </div>

  <!-- ORIGINELE BRON — alleen zichtbaar als 'venue' is ingesteld -->
  {venue && (
    <div class="container--narrow" style="margin-bottom: 1.5rem;">
      <div style="background: var(--color-accent-light); border: 1px solid var(--color-border); border-radius: 6px; padding: 0.875rem 1.125rem; font-size: 0.8125rem; color: var(--color-text-secondary);">
        Dit artikel verscheen oorspronkelijk op
        {venueUrl
          ? <a href={venueUrl} target="_blank" rel="noopener">{venue}</a>
          : <strong>{venue}</strong>
        }
        {' '}({date}). Gepubliceerd met toestemming.
      </div>
    </div>
  )}

  <!-- POST BODY -->
  <div class="container--narrow post-body">
    <slot />
  </div>

  <!-- TAGS + FOOTER -->
  <div class="container--narrow" style="padding-top: 2rem; padding-bottom: 3rem; border-top: 1px solid var(--color-border); margin-top: 2rem;">
    {tags && tags.length > 0 && (
      <div class="pill-group" style="margin-bottom: 1.5rem;">
        {tags.map(tag => (
          <span class="pill">{tag}</span>
        ))}
      </div>
    )}
    <p style="font-size: 0.8125rem; color: var(--color-text-muted);">
      <a href="/writing/">← Terug naar Writing</a>
    </p>
  </div>

</BaseLayout>

<style is:global>
  /* ─── Post body typography ─── */
  /* Lichte uitbreidingen van de globale stijl, enkel voor post-inhoud */

  .post-body h2 {
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .post-body h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.375rem;
  }

  .post-body p {
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
    text-align: justify;
  }

  .post-body strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .post-body a {
    color: var(--color-accent);
  }

  /* Blockquote */
  .post-body blockquote {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.0625rem;
    color: var(--color-text);
    line-height: 1.65;
  }

  .post-body blockquote p {
    margin-bottom: 0;
    color: var(--color-text);
    text-align: left;
  }

  /* Figuren / afbeeldingen */
  .post-body figure {
    margin: 1.75rem 0;
  }

  .post-body figure img {
    width: 100%;
    border-radius: 4px;
    border: 1px solid var(--color-border);
  }

  .post-body figcaption {
    font-size: 0.75rem;
    color: var(--color-text-faint);
    margin-top: 0.375rem;
    font-style: italic;
  }

  /* Figure label (bv. "Figuur 1") */
  .post-body .fig-label {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--color-text-faint);
    margin-bottom: 0.25rem;
  }

  /* Originele bron notitie */
  .post-body .source-note {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>
