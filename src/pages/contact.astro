---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact" description="Get in touch with Kamil Bernaerts.">
  <section class="page-header">
    <div class="container">
      <h1>Contact</h1>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 200px; gap: 2.5rem; align-items: start;">
        <div class="info-grid" style="border-top: none; padding-top: 0;">
          <div>
            <p class="info-grid__label">Email</p>
            <p class="info-grid__value">
              <a href="mailto:kamil.bernaerts@vub.be" class="email-badge" title="kamil.bernaerts@vub.be">✉ VUB</a>
              <a href="mailto:kamil.bernaerts@uhasselt.be" class="email-badge" title="kamil.bernaerts@uhasselt.be">✉ UHasselt</a>
              <a href="mailto:kamil.bernaerts@hannah-arendt.institute" class="email-badge" title="kamil.bernaerts@hannah-arendt.institute">✉ HAI</a>
            </p>
          </div>
          <div>
            <p class="info-grid__label">Office</p>
            <p class="info-grid__value">
              Vrije Universiteit Brussel<br>
              Pleinlaan 2<br>
              1050 Brussels, Belgium
            </p>
          </div>
          <div>
            <p class="info-grid__label">Online</p>
            <p class="info-grid__value">
              <a href="https://kamilbernaerts.bsky.social" target="_blank" rel="noopener">Bluesky</a><br>
              <a href="https://be.linkedin.com/in/kamil-bernaerts-431753201" target="_blank" rel="noopener">LinkedIn</a><br>
              <a href="https://scholar.google.com/citations?user=7Pmo70UAAAAJ&hl=en" target="_blank" rel="noopener">Google Scholar</a>
            </p>
          </div>
        </div>
        <div>
          <img src="/images/profiel-vub.jpeg" alt="Dr. Kamil Bernaerts" style="width: 200px; height: 200px; border-radius: 50%; object-fit: cover;" />
        </div>
      </div>
      <div style="max-width: 680px; margin-top: 2rem;">
        <h3 style="margin-bottom: 0.75rem;">For public engagement</h3>
        <p style="font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.75; margin-bottom: 1.5rem;">
          I am available for guest lectures, panel discussions, workshops, school visits, and media commentary 
          on topics related to polarisation, democratic resilience, and the state of democracy. 
          See my <a href="/outreach/">outreach page</a> for more details.
        </p>
        <h3 style="margin-bottom: 0.75rem;">For academic inquiries</h3>
        <p style="font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.75;">
          If you're interested in collaborating on research projects and papers or have questions about my work, please reach out via email. 
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .email-badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.75rem;
    font-family: var(--font-sans);
    font-weight: 500;
    padding: 0.2rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-text-secondary);
    text-decoration: none;
    margin-right: 0.3rem;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .email-badge:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    opacity: 1;
  }
</style>
