---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="CV" description="Academic curriculum vitae of Kamil Bernaerts.">

  <section class="page-header">
    <div class="container">
      <h1>Curriculum vitae</h1>
      <p class="lead">
        <a href="/Academic_cv_Kamil_Bernaerts.pdf" target="_blank" rel="noopener" style="display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; padding: 0.5rem 1rem; border: 1px solid var(--color-accent); border-radius: 4px; color: var(--color-accent);">
          Download full CV (PDF) →
        </a>
      </p>
    </div>
  </section>

  <!-- POSITIONS -->
  <section class="section">
    <div class="container">
      <p class="section__label">Positions</p>
      <div class="pub-item">
        <div>
          <p class="pub-title">Post-doctoral researcher</p>
          <p class="pub-authors">Vrije Universiteit Brussel · Programme: Evaluating Democratic Governance in Europe (EDGE)</p>
        </div>
        <div class="pub-meta"><p class="pub-year">2025–present</p></div>
      </div>
      <div class="pub-item">
        <div>
          <p class="pub-title">Guest professor (10% ZAP)</p>
          <p class="pub-authors">Universiteit Hasselt · Introduction to Political Science and Governance</p>
        </div>
        <div class="pub-meta"><p class="pub-year">2025–2026</p></div>
      </div>
      <div class="pub-item">
        <div>
          <p class="pub-title">Academic member</p>
          <p class="pub-authors">Hannah Arendt Institute for Diversity, Urbanity and Citizenship, Mechelen</p>
        </div>
        <div class="pub-meta"><p class="pub-year">2022–present</p></div>
      </div>
    </div>
  </section>

  <!-- EDUCATION -->
  <section class="section">
    <div class="container">
      <p class="section__label">Education</p>
      <div class="pub-item">
        <div>
          <p class="pub-title">PhD in Political Science</p>
          <p class="pub-authors">Vrije Universiteit Brussel &amp; University of Warwick (EUTOPIA Co-tutelle)</p>
        </div>
        <div class="pub-meta"><p class="pub-year">2021–2025</p></div>
      </div>
      <div class="pub-item">
        <div>
          <p class="pub-title">MSc Political Sciences: European and International Governance</p>
          <p class="pub-authors">Vrije Universiteit Brussel · Summa Cum Laude</p>
        </div>
        <div class="pub-meta"><p class="pub-year">2020–2021</p></div>
      </div>
      <div class="pub-item">
        <div>
          <p class="pub-title">BSc Social Sciences (minor Political Science)</p>
          <p class="pub-authors">Vrije Universiteit Brussel &amp; Universiteit Gent · Magna Cum Laude</p>
        </div>
        <div class="pub-meta"><p class="pub-year">2017–2020</p></div>
      </div>
    </div>
  </section>

  <!-- PRIZES -->
  <section class="section">
    <div class="container">
      <p class="section__label">Prizes &amp; awards</p>
      <div class="pub-item">
        <div>
          <p class="pub-title">Frank Cass Prize for Best Article of 2023</p>
          <p class="pub-authors">Democratization (journal)</p>
        </div>
        <div class="pub-meta"><p class="pub-year">2024</p></div>
      </div>
      <div class="pub-item">
        <div>
          <p class="pub-title">EUTOPIA Co-tutelle PhD Scholarship</p>
          <p class="pub-authors">EUTOPIA university alliance</p>
        </div>
        <div class="pub-meta"><p class="pub-year">2021</p></div>
      </div>
      <div class="pub-item">
        <div>
          <p class="pub-title">Excellence Award — top student in master's programme</p>
          <p class="pub-authors">Faculty of Economy and Social Sciences, VUB</p>
        </div>
        <div class="pub-meta"><p class="pub-year">2021</p></div>
      </div>
    </div>
  </section>

  <!-- SERVICE -->
  <section class="section">
    <div class="container">
      <p class="section__label">Professional service</p>
      <div class="pub-item">
        <div>
          <p class="pub-title">Peer reviewer</p>
          <p class="pub-authors">Acta Politica · Social Science Quarterly · Social Inclusion · European Journal of Political Research · Nature Human Behaviour</p>
        </div>
      </div>
      <div class="pub-item">
        <div>
          <p class="pub-title">Workshop co-organiser</p>
          <p class="pub-authors">"Polarising Performances or Reengaging the Audience?" · University of Warwick (2025)</p>
        </div>
      </div>
      <div class="pub-item">
        <div>
          <p class="pub-title">Panel chair</p>
          <p class="pub-authors">WVS Conference, King's College London (2024) · ECPR General Conference, Innsbruck (2022)</p>
        </div>
      </div>
      <div class="pub-item">
        <div>
          <p class="pub-title">Political Science &amp; Sociology Junior Talks</p>
          <p class="pub-authors">Co-organiser of interdisciplinary seminar series for junior researchers, VUB (2022–2024)</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SKILLS & LANGUAGES -->
  <section class="section">
    <div class="container">
      <div class="info-grid">
        <div>
          <p class="info-grid__label">Languages</p>
          <p class="info-grid__value">Dutch (native)<br>English (proficient)</p>
        </div>
        <div>
          <p class="info-grid__label">Research skills</p>
          <p class="info-grid__value">R (3+ years, self-taught)<br>Survey design &amp; fielding<br>Causal inference</p>
        </div>
        <div>
          <p class="info-grid__label">References</p>
          <p class="info-grid__value">
            Prof. Didier Caluwaerts (VUB)<br>
            Prof. Michael Saward (Warwick)<br>
            Dr. Nino Junius (VUB)
          </p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
