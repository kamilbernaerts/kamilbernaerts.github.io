---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" description="Political scientist at Vrije Universiteit Brussel, studying the fascinating relationship between conflict and democracy.">

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-layout">
        <div>
          <h1>Polarisation versus democracy?</h1>
          <p class="intro">
            I'm a political scientist studying social conflict and polarisation within democratic societies. 
            I specifically want to explore whether polarisation is indeed problematic for democracy, or not. 
            Currently I'm a postdoctoral researcher at Vrije Universiteit Brussel, guest professor at 
            Universiteit Hasselt, and academic member of the 
            <a href="https://hannah-arendt.institute/" target="_blank" rel="noopener">Hannah Arendt Institute</a>.
          </p>
          <p class="sub-intro">
            Winner of the <a href="https://www.tandfonline.com/journals/fdem20/collections/best-paper-frank-cass-prize" target="_blank" rel="noopener">Frank Cass Prize 2023</a> for best article in <em>Democratization</em>.
          </p>
          <div class="pill-group">
            <a href="/writing/" class="pill">Latest writing</a>
            <a href="/research/" class="pill">Publications</a>
            <a href="/cv/" class="pill">Academic CV</a>
            <a href="/outreach/" class="pill">Invite me</a>
          </div>
        </div>
        <div>
          <img src="/images/kamil-bernaerts.jpg" alt="Kamil Bernaerts" class="hero-photo" />
          <p style="font-size: 0.6875rem; color: var(--color-text-faint); margin-top: 0.375rem;">&copy; Greetje Van Buggenhout</p>
        </div>
      </div>
    </div>
  </section>

  <!-- INFO GRID -->
  <section class="container">
    <div class="info-grid">
      <div>
        <p class="info-grid__label">Position</p>
        <p class="info-grid__value">
          Postdoc, Vrije Universiteit Brussel<br>
          Guest Professor, Universiteit Hasselt<br>
          Academic Member, Hannah Arendt Instituut
        </p>
      </div>
      <div>
        <p class="info-grid__label">Research</p>
        <p class="info-grid__value">
          Affective polarisation<br>
          Democratic attitudes &amp; resilience<br>
          Political engagement &amp; conflict
        </p>
      </div>
      <div>
        <p class="info-grid__label">Supervision &amp; collaboration</p>
        <p class="info-grid__value">
          Prof. Didier Caluwaerts (VUB)<br>
          Prof. Michael Saward (Warwick)<br>
          Prof. Peter Thijssen (UAntwerpen)
        </p>
      </div>
    </div>
  </section>

  <!-- LATEST WRITING -->
  <section class="section">
    <div class="container">
      <p class="section__label">Latest writing</p>
      <div class="blog-grid">
        <a href="/writing/" class="blog-card">
          <span class="blog-card__lang">NL</span>
          <p class="blog-card__title">Binnenkort: eerste blogposts</p>
          <p class="blog-card__meta">Coming soon</p>
        </a>
        <a href="/writing/" class="blog-card">
          <span class="blog-card__lang">EN</span>
          <p class="blog-card__title">Coming soon: first public essays</p>
          <p class="blog-card__meta">Coming soon</p>
        </a>
      </div>
      <a href="/writing/" class="section__more">All writing →</a>
    </div>
  </section>

  <!-- RECENT PUBLICATIONS -->
  <section class="section">
    <div class="container">
      <p class="section__label">Recent publications</p>
      
      <div class="pub-item">
        <div>
          <p class="pub-title">Summary: Friends or foes, does polarisation really undermine democracy?</p>
          <p class="pub-authors">Bernaerts, K.</p>
        </div>
        <div class="pub-meta">
          <p class="pub-journal">Politics of the Low Countries</p>
          <p class="pub-year">2026 (accepted)</p>
        </div>
      </div>

      <div class="pub-item">
        <div>
          <p class="pub-title">Fight or unite? Exploring the link between consensus institutions, polarization, and political violence in 113 democracies over time (1900–2023)</p>
          <p class="pub-authors">Bernaerts, K. &amp; Caluwaerts, D.</p>
        </div>
        <div class="pub-meta">
          <p class="pub-journal">International Political Science Review</p>
          <p class="pub-year">2025</p>
        </div>
      </div>

      <div class="pub-item">
        <div>
          <p class="pub-title">Friends or foes: does polarisation really undermine democracy?</p>
          <p class="pub-authors">Bernaerts, K.</p>
        </div>
        <div class="pub-meta">
          <p class="pub-journal">VUBPRESS Brussels University Press</p>
          <p class="pub-year">2025 (book)</p>
        </div>
      </div>

      <a href="/research/" class="section__more">All publications →</a>
    </div>
  </section>

  <!-- CURRENT PROJECTS -->
  <section class="section">
    <div class="container">
      <p class="section__label">Current projects</p>
      <div class="project-grid">
        <div class="project-card">
          <p class="project-card__label">FWO Postdoctoral Fellowship</p>
          <p class="project-card__desc">Affective polarisation, political engagement, and democratic attitudes</p>
        </div>
        <div class="project-card">
          <p class="project-card__label">Book project</p>
          <p class="project-card__desc">Dutch-language book on political polarisation and democracy</p>
        </div>
        <div class="project-card">
          <p class="project-card__label">PACT School Tour</p>
          <p class="project-card__desc">Guest lectures on polarisation and critical thinking for secondary school students</p>
        </div>
        <div class="project-card">
          <p class="project-card__label">V-Dem / ERT analysis</p>
          <p class="project-card__desc">Causal relationship between political polarisation and autocratisation</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
