      </div>

      <div class="pub-item">
        <div>
          <p class="pub-title">La démocratie belge moins sensible à la polarisation</p>
          <p class="pub-authors"><a href="https://www.rtl.be/info/belgique/politique/la-democratie-belge-moins-sensible-a-la-polarisation-1420273.aspx" target="_blank" rel="noopener">RTL Info</a></p>
        </div>
        <div class="pub-meta"><p class="pub-year">2022</p></div>
      </div>
    </div>
  </section>

  <!-- PHOTO -->
  <section class="section">
  <div class="container">
    <figure style="display: flex; flex-direction: column; align-items: center; margin: 0; text-align: center;">
      <img 
        src="/images/public-speaking.jpg" 
        alt="Kamil Bernaerts giving a public lecture" 
        style="width: 100%; max-width: 800px; border-radius: 4px;" 
      />
      <figcaption style="font-size: 0.75rem; color: var(--color-text-faint); margin-top: 0.5rem;">
        &copy; Greetje Van Buggenhout
      </figcaption>
    </figure>
  </div>
</section>

</BaseLayout>
