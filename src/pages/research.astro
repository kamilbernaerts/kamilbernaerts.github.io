---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Research" description="My research explores how different forms of polarisation relate to democratic health.">

  <section class="page-header">
    <div class="container">
      <h1>Research</h1>
      <p class="lead">My work explores how different forms of polarisation relate to democratic health — when does conflict strengthen democracy, and when does it erode it?</p>
    </div>
  </section>

  <!-- RESEARCH THEMES -->
  <section class="section">
    <div class="container">
      <p class="section__label">Research themes</p>
      <div class="project-grid">
        <div class="project-card">
          <p class="project-card__label">Affective polarisation &amp; democracy</p>
          <p class="project-card__desc">How do different forms of affective polarisation — dislike, social distance, negative emotions — relate to support for liberal democracy?</p>
        </div>
        <div class="project-card">
          <p class="project-card__label">Institutions &amp; polarisation</p>
          <p class="project-card__desc">How do democratic institutions (consensus vs. majoritarian) shape polarisation dynamics and their consequences?</p>
        </div>
        <div class="project-card">
          <p class="project-card__label">Political engagement</p>
          <p class="project-card__desc">Does political engagement moderate the relationship between polarisation and anti-democratic attitudes?</p>
        </div>
        <div class="project-card">
          <p class="project-card__label">Polarisation &amp; political violence</p>
          <p class="project-card__desc">Under which institutional conditions does polarisation lead to political violence — and when does it not?</p>
        </div>
      </div>
    </div>
  </section>

