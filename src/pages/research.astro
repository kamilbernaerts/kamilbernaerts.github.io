---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<style>
  .research-sidebar {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding-top: 3.5rem;
  }

  .research-sidebar-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    text-decoration: none;
    transition: border-color 0.15s ease, background-color 0.15s ease;
    gap: 0.75rem;
  }

  .research-sidebar-link:hover {
    border-color: var(--color-accent);
    background-color: var(--color-accent-light);
    opacity: 1;
  }

  .research-sidebar-link__text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .research-sidebar-link__title {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-accent);
    line-height: 1.3;
  }

  .research-sidebar-link__sub {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .research-sidebar-link__arrow {
    font-size: 0.875rem;
    color: var(--color-text-faint);
    flex-shrink: 0;
    transition: color 0.15s ease, transform 0.15s ease;
  }

  .research-sidebar-link:hover .research-sidebar-link__arrow {
    color: var(--color-accent);
    transform: translateX(2px);
  }

  .research-header-figure {
    margin-top: 1.75rem;
  }

  @media (max-width: 768px) {
    .research-sidebar {
      padding-top: 0.25rem;
      flex-direction: row;
      flex-wrap: wrap;
    }

    .research-sidebar-link {
      flex: 1 1 calc(50% - 0.3125rem);
      min-width: 140px;
    }

    .research-header-figure {
      margin-top: 1.25rem;
    }
  }

  @media (max-width: 480px) {
    .research-sidebar {
      flex-direction: column;
    }

    .research-sidebar-link {
      flex: none;
      width: 100%;
    }
  }
</style>

<BaseLayout title="Research" description="My research explores how different forms of polarisation relate to democratic health.">

  <section class="page-header">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 240px; gap: 2rem; align-items: start;">
        <div>
          <h1>Research</h1>
          <p class="intro" style="text-align: justify;">My research is driven by a simple, yet challenging question: <strong>when does conflict become a threat to democracy?</strong> Our societies are (re)polarising (see below), and the most common reaction is to see that as inherently dangerous. My work, instead, is built on the conviction that understanding this distinction — between the conflict that democracies need and the conflict that destroys them — is one of the most urgent tasks for political science today. In doing so, I have developed a strong interest in studying different sorts of polarisation, and the broader socio-institutional framework within which it erupts.</p>
        </div>
        <div class="research-sidebar">
          <a href="https://scholar.google.com/citations?user=7Pmo70UAAAAJ&hl=en" target="_blank" rel="noopener" class="research-sidebar-link">
            <span class="research-sidebar-link__text">
              <span class="research-sidebar-link__title">Google Scholar</span>
              <span class="research-sidebar-link__sub">Full publication metrics</span>
            </span>
            <span class="research-sidebar-link__arrow">→</span>
          </a>
          <a href="https://researchportal.vub.be/en/persons/kamil-bernaerts" target="_blank" rel="noopener" class="research-sidebar-link">
            <span class="research-sidebar-link__text">
              <span class="research-sidebar-link__title">VUB Research Portal</span>
              <span class="research-sidebar-link__sub">Institutional profile</span>
            </span>
            <span class="research-sidebar-link__arrow">→</span>
          </a>
        </div>
      </div>
      <div class="research-header-figure">
        <figure style="display: flex; flex-direction: column; align-items: center; margin: 0;">
          <img src="/images/polarisation-vdem.png" alt="Figure depicting the global rise of polarisation according to V-Dem data" style="width: 100%; max-width: 800px; border-radius: 4px;" />
          <figcaption style="font-size: 0.75rem; color: var(--color-text-faint); margin-top: 0.5rem; text-align: center;">
            Global increase in idea-based and identity-based polarisation. Source: V-Dem (2026).
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- RESEARCH THEMES -->
  <section class="section">
    <div class="container">
      <p class="section__label">Research themes</p>
      <div class="project-grid">
        <div class="project-card">
          <p class="project-card__label">Kinds of polarisation and democracy</p>
          <p class="project-card__desc">How do different kinds of polarisation relate to democratic behavior?</p>
        </div>
        <div class="project-card">
          <p class="project-card__label">Institutions and polarisation</p>
          <p class="project-card__desc">How do democratic institutions shape polarisation dynamics and their consequences?</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PUBLISHED -->
  <section class="section">
    <div class="container">
      <p class="section__label">Published &amp; accepted articles and books</p>

      <!-- PSR: accepted, no link yet -->
      <div class="pub-item">
        <div>
          <p class="pub-title">Affect or emotions? Disaggregating affective polarisation to explain support for liberal democracy in Belgium and the United Kingdom</p>
          <p class="pub-authors">Bernaerts, K.</p>
        </div>
        <div class="pub-meta">
          <p class="pub-journal">Political Studies Review <span class="oa-badge oa-green" title="Green Open Access — accepted author manuscript will be made available upon publication">Green OA</span></p>
          <p class="pub-year">2026 (accepted)</p>
        </div>
      </div>

      <!-- PLC Summary: diamond OA, one link -->
      <div class="pub-item">
        <div>
          <p class="pub-title">Summary: Friends or foes, does polarisation really undermine democracy? Understanding the two-way relationship between polarisation dynamics and the processes and institutions of democratic contestation</p>
          <p class="pub-authors">Bernaerts, K.</p>
        </div>
        <div class="pub-meta">
          <p class="pub-journal">Politics of the Low Countries <span class="oa-badge oa-diamond" title="Diamond Open Access — freely available to read and download">Diamond OA</span></p>
          <p class="pub-year">2026</p>
          <div class="pub-links">
            <a href="https://plc-journal.eu/article/view/25310" target="_blank" rel="noopener" class="pub-link">published ↗</a>
          </div>
        </div>
      </div>

      <!-- VUBPRESS book: no link, no OA classification -->
      <div class="pub-item">
        <div>
          <p class="pub-title">Friends or foes: does polarisation really undermine democracy? Understanding the two-way relationship between polarisation dynamics and the processes and institutions of democratic contestation</p>
          <p class="pub-authors">Bernaerts, K.</p>
        </div>
        <div class="pub-meta">
          <p class="pub-journal">VUBPRESS</p>
          <p class="pub-year">2025 (book)</p>
        </div>
      </div>

      <!-- IPSR: green OA, published + AAM -->
      <div class="pub-item">
        <div>
          <p class="pub-title">Fight or unite? Exploring the link between consensus institutions, polarization and political violence in 113 democracies over time (1900–2023)</p>
          <p class="pub-authors">Bernaerts, K. &amp; Caluwaerts, D.</p>
        </div>
        <div class="pub-meta">
          <p class="pub-journal">International Political Science Review <span class="oa-badge oa-green" title="Green Open Access — accepted author manuscript available">Green OA</span></p>
          <p class="pub-year">2025</p>
          <div class="pub-links">
            <a href="https://journals.sagepub.com/doi/10.1177/01925121251355894" target="_blank" rel="noopener" class="pub-link">published ↗</a>
            <a href="https://researchportal.vub.be/en/publications/fight-or-unite-exploring-the-link-between-consensus-institutions-/" target="_blank" rel="noopener" class="pub-link">AAM ↗</a>
          </div>
        </div>
      </div>

      <!-- Democratization: gold OA, one link -->
      <div class="pub-item">
        <div>
          <p class="pub-title">Institutional design and polarization. Do consensus democracies fare better in fighting polarization than majoritarian democracies?</p>
          <p class="pub-authors">Bernaerts, K., Blanckaert, B.; Caluwaerts, D.</p>
        </div>
        <div class="pub-meta">
          <p class="pub-journal">Democratization <span class="oa-badge oa-gold" title="Gold Open Access — freely available via publisher">Gold OA</span></p>
          <p class="pub-year">2023</p>
          <div class="pub-links">
            <a href="https://www.tandfonline.com/doi/full/10.1080/13510347.2022.2117300" target="_blank" rel="noopener" class="pub-link">published ↗</a>
          </div>
        </div>
      </div>

      <!-- Frontiers: gold OA, one link -->
      <div class="pub-item">
        <div>
          <p class="pub-title">Deliberation and polarization: a multi-disciplinary review</p>
          <p class="pub-authors">Caluwaerts, D., Bernaerts, K., Kesberg, R., Smets, L.; Spruyt, B.</p>
        </div>
        <div class="pub-meta">
          <p class="pub-journal">Frontiers in Political Science <span class="oa-badge oa-gold" title="Gold Open Access — freely available via publisher">Gold OA</span></p>
          <p class="pub-year">2023</p>
          <div class="pub-links">
            <a href="https://www.frontiersin.org/journals/political-science/articles/10.3389/fpos.2023.1127372/" target="_blank" rel="noopener" class="pub-link">published ↗</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WORKING PAPERS -->
  <section class="section">
    <div class="container">
      <p class="section__label">Under review &amp; working papers</p>

      <!-- Politics: no link -->
      <div class="pub-item">
        <div>
          <p class="pub-title">Hate, not dislike? Understanding anti-democratic attitudes through a multi-dimensional understanding of affective polarisation</p>
          <p class="pub-authors">Bernaerts, K.</p>
        </div>
        <div class="pub-meta">
          <p class="pub-journal">Politics</p>
          <p class="pub-year">Under review</p>
        </div>
      </div>

      <!-- Acta Politica: preprint link -->
      <div class="pub-item">
        <div>
          <p class="pub-title">Polarising alone? The relationship between social contact and affective polarisation in Belgium and the UK</p>
          <p class="pub-authors">Bernaerts, K. &amp; Junius, N.</p>
        </div>
        <div class="pub-meta">
          <p class="pub-journal">Acta Politica</p>
          <div class="pub-links">
            <a href="https://www.researchsquare.com/article/rs-9031632/v1" target="_blank" rel="noopener" class="pub-link">preprint ↗</a>
          </div>
        </div>
      </div>

      <!-- Working paper: no link -->
      <div class="pub-item">
        <div>
          <p class="pub-title">Beyond the culture wars? Assessing the socio-economic determinants of affective polarization</p>
          <p class="pub-authors">Bernaerts, K., Matthieu, J., Junius, N.; Caluwaerts, D.</p>
        </div>
        <div class="pub-meta">
          <p class="pub-journal"></p>
          <p class="pub-year">Working paper</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <figure style="display: flex; flex-direction: column; align-items: center; margin: 0;">
        <img src="/images/conference.png" alt="Presentation at ECPR General Conference 2022" style="width: 100%; max-width: 800px; border-radius: 4px;" />
        <figcaption style="font-size: 0.75rem; color: var(--color-text-faint); margin-top: 0.5rem; text-align: center;">
          Presentation at ECPR General Conference 2022.
        </figcaption>
      </figure>
    </div>
  </section>

</BaseLayout>
