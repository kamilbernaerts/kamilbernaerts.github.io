---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Writing" description="Public essays and blog posts on polarisation, democracy, and society.">

  <section class="page-header">
    <div class="container">
      <h1>Writing</h1>
      <p class="lead">Gedachten over polarisatie, democratie, en de maatschappij — voor een breder publiek dan de academische wereld. Thoughts on polarisation, democracy, and society — for a wider audience.</p>
    </div>
  </section>

  <section class="section">
    <div class="container container--narrow">
      <div style="padding: 3rem 0; text-align: center;">
        <p style="font-size: 1.125rem; color: var(--color-text-muted); font-family: var(--font-serif);">Coming soon.</p>
        <p style="font-size: 0.875rem; color: var(--color-text-faint); margin-top: 0.5rem;">
          I'm working on a series of essays in both Dutch and English. Follow along via 
          <a href="https://kamilbernaerts.bsky.social" target="_blank" rel="noopener">Bluesky</a> 
          to be notified when the first posts go live.
        </p>
      </div>
    </div>
  </section>

</BaseLayout>
