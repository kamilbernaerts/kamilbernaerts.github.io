---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Writing" description="Blog posts, opinion pieces, and public-facing commentary on democracy, polarization, and political institutions.">

  <div class="page-header">
    <div class="container">
      <h1>Writing</h1>
      <p class="lead">Blog posts and op-eds on democracy, polarisation, and political institutions — in Dutch and English.</p>
    </div>
  </div>

  <section class="section">
    <div class="container--narrow">

      <!-- ══════════════════════════════════════════════
           VOEG HIER EEN BLOK TOE PER NIEUWE POST.
           Kopieer het <a class="blog-item"> blok hieronder.
           ══════════════════════════════════════════════ -->

      <a href="/writing/polarisatie-democratieen/" class="blog-item" style="text-decoration: none; display: grid; grid-template-columns: 100px 1fr; gap: 1.5rem; padding: 1.75rem 0; border-top: 1px solid var(--color-border); color: inherit;">
        <div>
          <p class="blog-item__date">20 okt. 2022</p>
          <p class="blog-item__reading-time">~5 min</p>
          <p style="font-size: 0.6875rem; color: var(--color-accent); margin-top: 0.375rem; font-weight: 500;">NL</p>
        </div>
        <div>
          <p class="blog-item__title">Waarom kampen sommige democratieën meer met polarisatie dan andere?</p>
          <p class="blog-item__excerpt">Politieke instellingen verklaren waarom consensusdemocratieën minder polarisatie vertonen dan meerderheidsdemocratieën — en wat dat betekent voor beleidsmakers.</p>
          <p style="font-size: 0.75rem; color: var(--color-text-faint); margin-top: 0.375rem;">met Benjamin Blanckaert &amp; Didier Caluwaerts · Stuk Rood Vlees</p>
        </div>
      </a>

      <!-- TEMPLATE VOOR NIEUWE POSTS — kopieer dit blok en verwijder de commentaar-tags:

      <a href="/writing/JOUW-POST-SLUG/" class="blog-item" style="text-decoration: none; display: grid; grid-template-columns: 100px 1fr; gap: 1.5rem; padding: 1.75rem 0; border-top: 1px solid var(--color-border); color: inherit;">
        <div>
          <p class="blog-item__date">DD mmm. JJJJ</p>
          <p class="blog-item__reading-time">~X min</p>
          <p style="font-size: 0.6875rem; color: var(--color-accent); margin-top: 0.375rem; font-weight: 500;">NL of EN</p>
        </div>
        <div>
          <p class="blog-item__title">Titel van de post</p>
          <p class="blog-item__excerpt">Korte samenvatting in 1-2 zinnen.</p>
          <p style="font-size: 0.75rem; color: var(--color-text-faint); margin-top: 0.375rem;">solo / met Naam Coauteur · Naam publicatie</p>
        </div>
      </a>

      -->

    </div>
  </section>

</BaseLayout>
