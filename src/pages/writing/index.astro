---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Writing" description="Blog posts and op-eds on democracy, polarisation, and political institutions.">

  <div class="page-header">
    <div class="container">
      <h1>Writing</h1>
      <p class="lead">Blog posts and op-eds on democracy, polarisation, and political institutions — in Dutch and English.</p>
    </div>
  </div>

  <section class="section">
    <div class="container--narrow">

      <!--
      ════════════════════════════════════════════════════════════
      HOE VOEG JE EEN NIEUWE POST TOE?

      1. Kopieer het blok tussen "BEGIN POST" en "EINDE POST"
      2. Plak het BOVEN het bestaande blok (nieuwste post bovenaan)
      3. Vervang de waarden — alles wat tussen aanhalingstekens staat
      ════════════════════════════════════════════════════════════
      -->


      <!-- ═══════════ BEGIN POST ═══════════ -->
      <a href="/writing/bataljong-polarisatie/"
         style="text-decoration: none; color: inherit; display: grid; grid-template-columns: 140px 1fr; gap: 1.5rem; padding: 1.75rem 0; border-top: 1px solid var(--color-border); align-items: start;">

        <div>
          <!-- Geen afbeelding beschikbaar — verwijder commentaar en pas src aan als je er een hebt:
          <img src="/images/bataljong-header.jpg" alt="Polarisatie"
               style="width: 100%; height: 90px; object-fit: cover; border-radius: 4px; border: 1px solid var(--color-border); display: block;" />
          -->
          <p class="blog-item__date">1 sep. 2024</p>
          <p style="font-size: 0.6875rem; color: var(--color-accent); font-weight: 500; margin-top: 0.2rem;">NL</p>
          <p style="font-size: 0.6875rem; color: var(--color-text-faint); margin-top: 0.2rem;">Dropzone (Bataljong)</p>
        </div>

        <div>
          <p class="blog-item__title">Wanneer wij niet meer jij en ik zijn, maar zij, die en hij</p>
          <p class="blog-item__excerpt">Polarisatie hoeft niet altijd slecht te zijn — maar groepsdenken, een vijandsbeeld en sterke negatieve emoties zijn wel degelijk alarmsignalen.</p>
          <div class="pill-group" style="margin-top: 0.625rem;">
            <span class="pill">Polarisatie</span>
            <span class="pill">Democratie</span>
            <span class="pill">Jongeren</span>
          </div>
        </div>

      </a>
      <!-- ═══════════ EINDE POST ═══════════ -->


      <!-- ═══════════ BEGIN POST ═══════════ -->
      <a href="/writing/polarisatie-democratieen/"
         style="text-decoration: none; color: inherit; display: grid; grid-template-columns: 140px 1fr; gap: 1.5rem; padding: 1.75rem 0; border-top: 1px solid var(--color-border); align-items: start;">

        <div>
          <img src="/images/post1-header.jpg" alt="Polarisatie en democratie"
               style="width: 100%; height: 90px; object-fit: cover; border-radius: 4px; border: 1px solid var(--color-border); display: block;" />
          <p class="blog-item__date">20 okt. 2022</p>
          <p style="font-size: 0.6875rem; color: var(--color-accent); font-weight: 500; margin-top: 0.2rem;">NL</p>
          <p style="font-size: 0.6875rem; color: var(--color-text-faint); margin-top: 0.2rem;">Stuk Rood Vlees</p>
        </div>

        <div>
          <p class="blog-item__title">Waarom kampen sommige democratieën meer met polarisatie dan andere?</p>
          <p class="blog-item__excerpt">Politieke instellingen verklaren waarom consensusdemocratieën minder gepolariseerd zijn — en wat dat betekent voor beleidsmakers.</p>
          <div class="pill-group" style="margin-top: 0.625rem;">
            <span class="pill">Polarisatie</span>
            <span class="pill">Democratie</span>
            <span class="pill">Instellingen</span>
          </div>
          <p style="font-size: 0.75rem; color: var(--color-text-faint); margin-top: 0.375rem;">
            met Benjamin Blanckaert &amp; Didier Caluwaerts
          </p>
        </div>

      </a>
      <!-- ═══════════ EINDE POST ═══════════ -->


    </div>
  </section>

</BaseLayout>
